{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Tardigrade CI Server",
			"type": "shell",
			"command": "env",
			"args": [
				"-u",
				"https_proxy",
				"-u",
				"http_proxy",
				"-u",
				"PXY_FAB_FONC",
				"cargo",
				"run",
				"-p",
				"tardigrade-server"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Test Tardigrade CI Workspace",
			"type": "shell",
			"command": "env",
			"args": [
				"-u",
				"https_proxy",
				"-u",
				"http_proxy",
				"-u",
				"PXY_FAB_FONC",
				"cargo",
				"test",
				"--workspace"
			],
			"group": "build"
		},
		{
			"label": "Coverage Gate (75%)",
			"type": "shell",
			"command": "./scripts/coverage.sh",
			"args": [
				"75"
			],
			"group": "test"
		}
	]
}